{
  "name": "bollinger-trader",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "preview": "wrangler dev",
    "deploy": "npm run build && wrangler deploy",
    "deploy:dry": "npm run build && wrangler deploy --dry-run",
    "dev:local": "wrangler dev --test-scheduled --local",
    "db:create": "wrangler d1 create bollinger-trader-production",
    "db:migrate:local": "wrangler d1 migrations apply bollinger-trader-production --local",
    "db:migrate:prod": "wrangler d1 migrations apply bollinger-trader-production --remote",
    "db:seed": "wrangler d1 execute bollinger-trader-production --local --file=./seed.sql",
    "db:reset": "rm -rf .wrangler/state/v3/d1 && npm run db:migrate:local",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings"
  },
  "dependencies": {
    "hono": "^4.12.26"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260623.1",
    "@hono/vite-build": "^1.2.0",
    "@hono/vite-dev-server": "^0.25.2",
    "vite": "^6.3.5",
    "vitest": "^4.1.10",
    "wrangler": "^4.4.0"
  }
}
